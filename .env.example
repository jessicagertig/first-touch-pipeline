# ---- Claude ----
ANTHROPIC_API_KEY=

# ---- Slack ----
SLACK_BOT_TOKEN=            # xoxb-... bot token, scopes: channels:history, chat:write, reactions:read
SLACK_LEADS_CHANNEL_ID=        # app-prod-new-companies (source: Polymer's "New Company" posts; bot reads)
SLACK_GOOD_LEADS_CHANNEL_ID=  # new-leads-from-signups (pipeline posts each qualified good lead here)
SLACK_REVIEW_CHANNEL_ID=      # email-review (pipeline posts draft variations; bot reads ✅ reactions here) (Jessica to provide)

# ---- GitHub (workflow_dispatch from the Slack Lambda) ----
GITHUB_OWNER=
GITHUB_REPO=first-touch-pipeline
GITHUB_TOKEN=              # PAT with actions:write on this repo

# ---- Gmail API (jessica@polymer.co draft creation) ----
# One-time OAuth: a desktop/web OAuth client + a stored refresh token.
# Scope: https://www.googleapis.com/auth/gmail.compose
GMAIL_SENDER=jessica@polymer.co
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ---- Models (pin exact current IDs at build) ----
RESEARCH_MODEL=claude-sonnet-4-6      # research / web-search lane
DRAFT_MODEL=claude-opus-4-8           # draft / review lane

# ---- Tuning ----
DRAFT_VARIATIONS=5
REVIEW_SHIP_SCORE=8
REVIEW_MAX_ROUNDS=5
VERIFY_MAX_LOOPS=5
